# Server Configuration
PORT=3000
BACKEND_BASE_URL=http://localhost:3000

# CORS Configuration
FRONTEND_URL=http://localhost:3001

# External APIs
TOOLHUB_API_URL=https://api.toolhub.app/hust

# Tài khoản admin nội bộ (dùng để test, không cần tài khoản giảng viên HUST)
# Tất cả giảng viên HUST có đuôi @hust.edu.vn đều có thể đăng nhập qua API HUST
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password_here

# Tài khoản nội bộ thứ 2 (tuỳ chọn)
ADMIN_EMAIL_2=admin2@example.com
ADMIN_PASSWORD_2=secret2

# Secret key để ký JWT token (thay bằng chuỗi ngẫu nhiên, bí mật)
JWT_SECRET=change_this_to_a_long_random_secret_key

# Thời gian hết hạn của JWT token (ví dụ: 8h, 24h, 7d)
JWT_EXPIRES_IN=8h

# PostgreSQL connection

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=classportrait
